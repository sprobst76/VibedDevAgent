[Unit]
Description=DevAgent Core Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Replace YOUR_USERNAME with your OS user (needs access to claude CLI).
# See TODO.md #14 for the plan to switch to a dedicated service user.
User=YOUR_USERNAME
WorkingDirectory=/home/YOUR_USERNAME/development/VibedDevAgent
EnvironmentFile=/srv/devagent/.env
Environment=PYTHONUNBUFFERED=1
# Adjust PATH to include your user's local bin and nvm node directory.
Environment=PATH=/home/YOUR_USERNAME/.local/bin:/home/YOUR_USERNAME/.nvm/versions/node/current/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/usr/bin/env bash -lc 'python3 -m core.matrix_worker'
Restart=on-failure
RestartSec=3
StandardOutput=append:/var/log/devagent/core.log
StandardError=append:/var/log/devagent/core.log

# ── Systemd security hardening ────────────────────────────────────────────────
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ReadWritePaths=/srv/devagent /var/log/devagent /home/YOUR_USERNAME/development /srv/repos /srv/agent-artifacts /tmp
ProtectHome=read-only
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
LockPersonality=yes
RestrictRealtime=yes

[Install]
WantedBy=multi-user.target
