[Unit]
Description=DevAgent Core Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# TEMPORARY: running as spro for claude CLI access (Option A).
# TODO: switch back to devagent once Option C is implemented (see TODO.md #14).
User=spro
WorkingDirectory=/srv/devagent
EnvironmentFile=/srv/devagent/.env
Environment=PYTHONUNBUFFERED=1
Environment=PATH=/home/spro/.local/bin:/home/spro/.nvm/versions/node/v24.11.1/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/usr/bin/env bash -lc 'python3 -m core.matrix_worker'
Restart=on-failure
RestartSec=3
StandardOutput=append:/var/log/devagent/core.log
StandardError=append:/var/log/devagent/core.log

# ── Systemd security hardening ────────────────────────────────────────────────
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ReadWritePaths=/srv/devagent /var/log/devagent /home/spro/development /srv/repos /srv/agent-artifacts /tmp
ProtectHome=read-only
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
LockPersonality=yes
RestrictRealtime=yes

[Install]
WantedBy=multi-user.target
