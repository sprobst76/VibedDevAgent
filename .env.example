# Core
DEVAGENT_LOG_LEVEL=INFO
DEVAGENT_ALLOWED_USERS=@alice:example.org,@bob:example.org

# Matrix
MATRIX_HOMESERVER_URL=https://matrix.example.org
MATRIX_ACCESS_TOKEN=replace-me
MATRIX_ROOM_ID=!replace:example.org
DEVAGENT_MATRIX_STATE_FILE=/srv/devagent/state/matrix_worker_state.json
DEVAGENT_MATRIX_SYNC_TIMEOUT_MS=30000
DEVAGENT_MATRIX_RETRY_SLEEP_SECONDS=2.0
DEVAGENT_MATRIX_SEND_NOTICES=1

# Matrix auto-relogin (optional — used when token expires)
MATRIX_USER_DEVAGENT=@devagent:example.org
MATRIX_PASSWORD_DEVAGENT=replace-me

# Telegram
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_ALLOWED_CHAT_IDS=12345,67890

# Paths
DEVAGENT_REPOS_ROOT=/srv/repos
DEVAGENT_WORKTREES_ROOT=/srv/agent-worktrees
DEVAGENT_ARTIFACTS_ROOT=/srv/agent-artifacts
DEVAGENT_PROJECTS_FILE=/srv/devagent/state/projects.json
DEVAGENT_LOG_FILE=/var/log/devagent/worker.log

# Web UI
# Leave empty to disable authentication (local development only).
# Set a strong random value for any internet-accessible deployment.
DEVAGENT_UI_API_KEY=replace-me
